*.log

# Env (secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Vercel
.vercel

# TypeScript / tooling
*.tsbuildinfo

# ESLint / Prettier cache
.eslintcache
.prettiercache

# Turbo
.turbo

# IDE / editor (opcional; quita líneas si versionás .vscode para el equipo)
.idea/
*.swp
*.swo
*~

# OS / temp
.tmp
.temp
.cache/
